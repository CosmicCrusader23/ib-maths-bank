{"id": 7199, "source": "pestle", "subject": "chemistry", "course": null, "level": "SL", "paper": "3", "year": "2017", "session": "17N", "subtopic": "d-1-pharmaceutical-products-and-drug-action", "title": "17N.3.SL.TZ0.18", "topic_id": "d", "source_url": "https://pestle.pages.dev/app/", "question_html": "<div class=\"specification\">\n<p>New drugs undergo thorough clinical trials before they are approved.</p>\n</div><div class=\"question\" style=\"padding-left: 20px; padding-right: 20px;\">\n<p>Outline the difference between the therapeutic index in animal studies and the therapeutic index in humans.</p>\n<div class=\"marks\">[1]</div>\n<div class=\"question_part_label\">a.</div>\n</div><div class=\"question\" style=\"padding-left: 20px; padding-right: 20px;\">\n<p>State the method of drug administration that gives the maximum bioavailability.</p>\n<div class=\"marks\">[1]</div>\n<div class=\"question_part_label\">b.</div>\n</div>", "solution_html": "<div class=\"question\" style=\"padding-left: 20px;\">\n<p>in animal studies <span class=\"mjpage\"><math alttext=\"\\frac{{{\\text{LD50}}}}{{{\\text{ED50}}}}\" xmlns=\"http://www.w3.org/1998/Math/MathML\">\n<mfrac>\n<mrow>\n<mrow>\n<mtext>LD50</mtext>\n</mrow>\n</mrow>\n<mrow>\n<mrow>\n<mtext>ED50</mtext>\n</mrow>\n</mrow>\n</mfrac>\n</math></span> <em><strong>AND</strong></em> in humans <span class=\"mjpage\"><math alttext=\"\\frac{{{\\text{TD50}}}}{{{\\text{ED50}}}}\" xmlns=\"http://www.w3.org/1998/Math/MathML\">\n<mfrac>\n<mrow>\n<mrow>\n<mtext>TD50</mtext>\n</mrow>\n</mrow>\n<mrow>\n<mrow>\n<mtext>ED50</mtext>\n</mrow>\n</mrow>\n</mfrac>\n</math></span></p>\n<p><em><strong>OR</strong></em></p>\n<p>in animal studies lethal dose/LD50 <em><strong>AND</strong> </em>in humans toxic dose/TD50</p>\n<div class=\"question_part_label\">a.</div>\n</div><div class=\"question\" style=\"padding-left: 20px;\">\n<p>intravenous/IV «injection»</p>\n<p><em><strong>OR</strong></em></p>\n<p>injection into the bloodstream</p>\n<div class=\"question_part_label\">b.</div>\n</div>", "examiners_html": "<div class=\"question\" style=\"padding-left: 20px;\">\n[N/A]\n<div class=\"question_part_label\">a.</div>\n</div><div class=\"question\" style=\"padding-left: 20px;\">\n[N/A]\n<div class=\"question_part_label\">b.</div>\n</div>"}