{"id": 15131, "source": "pestle", "subject": "biology", "course": null, "level": "SL", "paper": "1", "year": "2020", "session": "20N", "subtopic": "6-2-the-blood-system", "title": "20N.1.SL.TZ0.25", "topic_id": "6", "source_url": "https://pestle.pages.dev/app/", "question_html": "<div class=\"question\">\n<p style=\"text-align: left;\">What feature of arteries is most important in maintaining sufficiently high blood pressure?</p>\n<p style=\"text-align: left;\">A. A wide lumen</p>\n<p style=\"text-align: left;\">B. Elastic fibres in the wall</p>\n<p style=\"text-align: left;\">C. Valves at intervals</p>\n<p style=\"text-align: left;\">D. A thin wall</p>\n</div>", "solution_html": "<div class=\"question\">\n<p>B</p>\n</div>", "examiners_html": "<div class=\"question\">\n[N/A]\n</div>"}