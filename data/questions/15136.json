{"id": 15136, "source": "pestle", "subject": "biology", "course": null, "level": "SL", "paper": "1", "year": "2020", "session": "20N", "subtopic": "6-3-defence-against-infectious-disease", "title": "20N.1.SL.TZ0.26", "topic_id": "6", "source_url": "https://pestle.pages.dev/app/", "question_html": "<div class=\"question\">\n<p style=\"text-align: left;\">What is a feature of phagocytic white blood cells?</p>\n<p style=\"text-align: left;\">A. Stimulate blood clotting</p>\n<p style=\"text-align: left;\">B. Found only in the circulatory system</p>\n<p style=\"text-align: left;\">C. Form part of non-specific immunity</p>\n<p style=\"text-align: left;\">D. Produce antibodies</p>\n</div>", "solution_html": "<div class=\"question\">\n<p>C</p>\n</div>", "examiners_html": "<div class=\"question\">\n[N/A]\n</div>"}