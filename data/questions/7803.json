{"id": 7803, "source": "pestle", "subject": "chemistry", "course": null, "level": "SL", "paper": "1", "year": "2019", "session": "19M", "subtopic": "11-1-uncertainties-and-errors-in-measurement-and-results", "title": "19M.1.SL.TZ1.28", "topic_id": "11", "source_url": "https://pestle.pages.dev/app/", "question_html": "<div class=\"question\">\n<p><span style=\"background-color: #ffffff;\">How should a measurement of 5.00 g from a balance be recorded?</span></p>\n<p><span style=\"background-color: #ffffff;\">A. 5.00 ± 0.1 g</span></p>\n<p><span style=\"background-color: #ffffff;\">B. 5.00 ± 0.01 g</span></p>\n<p><span style=\"background-color: #ffffff;\">C. 5.00 ± 1 g</span></p>\n<p><span style=\"background-color: #ffffff;\">D. 5.00 ± 0.001 g</span></p>\n</div>", "solution_html": "<div class=\"question\">\n<p>B</p>\n</div>", "examiners_html": "<div class=\"question\">\n<p>80 % of candidates could correctly identify uncertainty.</p>\n</div>"}