{"id": 14962, "source": "pestle", "subject": "biology", "course": null, "level": "SL", "paper": "1", "year": "2018", "session": "18N", "subtopic": "6-6-hormones-homeostasis-and-reproduction", "title": "18N.1.SL.TZ0.30", "topic_id": "6", "source_url": "https://pestle.pages.dev/app/", "question_html": "<div class=\"question\">\n<p style=\"text-align: left;\">Which pituitary hormones regulate the human menstrual cycle?</p>\n<p style=\"text-align: left;\">A.  FSH and LH</p>\n<p style=\"text-align: left;\">B.  Progesterone and estrogen</p>\n<p style=\"text-align: left;\">C.  HCG and estrogen</p>\n<p style=\"text-align: left;\">D.  FSH and oxytocin</p>\n</div>", "solution_html": "<div class=\"question\">\n<p>A</p>\n</div>", "examiners_html": "<div class=\"question\">\n[N/A]\n</div>"}