{"id": 6802, "source": "pestle", "subject": "chemistry", "course": null, "level": "HL", "paper": "1", "year": "2019", "session": "19M", "subtopic": "9-1-oxidation-and-reduction", "title": "19M.1.HL.TZ2.28", "topic_id": "9", "source_url": "https://pestle.pages.dev/app/", "question_html": "<div class=\"question\">\n<p><span style=\"background-color: #ffffff;\">Which compound contains sulfur with an oxidation state of +6?</span></p>\n<p><span style=\"background-color: #ffffff;\">A. SO<sub>2</sub></span></p>\n<p><span style=\"background-color: #ffffff;\">B. H<sub>2</sub>S</span></p>\n<p><span style=\"background-color: #ffffff;\">C. H<sub>2</sub>SO<sub>3</sub></span></p>\n<p><span style=\"background-color: #ffffff;\">D. H<sub>2</sub>SO<sub>4</sub></span></p>\n</div>", "solution_html": "<div class=\"question\">\n<p>D</p>\n</div>", "examiners_html": "<div class=\"question\">\n<p>94 % of candidates identified the compound that contains sulfur with an oxidation state of +6.</p>\n</div>"}